{
  "installCommand": "pnpm install",
  "buildCommand": "PORT=3000 BASE_PATH=/ pnpm --filter @workspace/leilao-cb run build",
  "outputDirectory": "dist",
  "framework": null,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
